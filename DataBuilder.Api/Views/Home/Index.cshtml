@{
    ViewData["Title"] = "DataBuilder";
}

<div class="text-center mb-5">
    <h1 class="display-4">DataBuilder</h1>
    <p class="lead text-muted">Alpaca 数据集构建系统 — 导入文档，自动生成 QA 对，导出 JSONL 微调数据集</p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">项目管理</h5>
                <p class="card-text text-muted">创建和管理数据集项目，每个项目包含一组文档和 QA 对。</p>
                <a asp-controller="Project" asp-action="Index" class="btn btn-primary">进入项目列表</a>
                <a asp-controller="Project" asp-action="Create" class="btn btn-outline-primary ms-1">新建项目</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h5 class="card-title">工作流程</h5>
                <p class="card-text text-muted">
                    1. 创建项目 → 2. 上传 .md/.txt 文档 → 3. 分段解析 → 4. LLM 生成 QA 对 → 5. 导出 JSONL
                </p>
            </div>
        </div>
    </div>
</div>
