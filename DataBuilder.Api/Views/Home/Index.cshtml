@model IEnumerable<DataBuilder.Core.Entities.Project>
@inject Microsoft.Extensions.Options.IOptions<DataBuilder.Api.Models.SiteOptions> SiteConfig

@{
    ViewData["Title"] = SiteConfig.Value.AppName;
}

@* ===== Hero 区域 ===== *@
<section class="hero-section">
    <div class="hero-pattern"></div>
    <div class="hero-content">
        <h1 class="hero-title">@SiteConfig.Value.AppName</h1>
        <p class="hero-subtitle">@SiteConfig.Value.Description</p>
        <div class="hero-actions">
            <a asp-controller="Project" asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> 创建项目
            </a>
        </div>
    </div>
</section>

@* ===== 项目卡片网格 ===== *@
@if (Model != null && Model.Any())
{
    <div class="project-grid">
        @foreach (var project in Model)
        {
            var docCount = project.Documents?.Count ?? 0;
            var qaCount = project.Documents?.Sum(d => d.Chunks?.Sum(c => c.QAPairs?.Count ?? 0) ?? 0) ?? 0;
            var displayId = $"PRJ-{project.Id:X8}";
            var firstLetter = string.IsNullOrEmpty(project.Name)
                ? "P"
                : project.Name[0].ToString().ToUpper();

            <div class="project-card-link" style="cursor:pointer"
                 onclick="window.location.href='@Url.Action("Detail", "Project", new { id = project.Id })'"
                 role="link" tabindex="0"
                 onkeydown="if(event.key==='Enter')window.location.href='@Url.Action("Detail", "Project", new { id = project.Id })'">
                <div class="project-card card">
                    <div class="card-body">
                        @* 卡片头部: 图标 + 标题 + 菜单 *@
                        <div class="card-top">
                            <div class="project-icon-block">
                                <span>@firstLetter</span>
                            </div>
                            <div class="project-info">
                                <h5 class="project-title">@project.Name</h5>
                                <span class="project-id">ID: @displayId</span>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-icon" type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                        onclick="event.stopPropagation()">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Project" asp-action="Detail" asp-route-id="@project.Id"
                                           onclick="event.stopPropagation()">
                                            <i class="bi bi-box-arrow-in-right me-2"></i>进入项目
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Project" asp-action="Settings" asp-route-id="@project.Id"
                                           onclick="event.stopPropagation()">
                                            <i class="bi bi-gear me-2"></i>设置
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Project" asp-action="Delete" asp-route-id="@project.Id"
                                              method="post"
                                              onsubmit="return confirm('确定要删除项目 @project.Name.Replace("'", "\\'") 吗？')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger"
                                                    onclick="event.stopPropagation()">
                                                <i class="bi bi-trash me-2"></i>删除
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        @* 描述 *@
                        <p class="project-desc">
                            @(string.IsNullOrWhiteSpace(project.Description)
                                ? "暂无描述"
                                : (project.Description.Length > 80 ? project.Description[..80] + "..." : project.Description))
                        </p>

                        @* 2x2 统计网格 *@
                        <div class="project-stats">
                            <div class="stat-item">
                                <i class="bi bi-file-text stat-icon stat-icon-blue"></i>
                                <span class="stat-value">@docCount</span>
                                <span class="stat-label">文档</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-chat-square-text stat-icon stat-icon-purple"></i>
                                <span class="stat-value">@qaCount</span>
                                <span class="stat-label">问答对</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-bar-chart stat-icon stat-icon-green"></i>
                                <span class="stat-value">0</span>
                                <span class="stat-label">已导出</span>
                            </div>
                            <div class="stat-item">
                                <i class="bi bi-calendar3 stat-icon stat-icon-orange"></i>
                                <span class="stat-value">@project.CreatedAt.ToBeijingTime().ToString("yyyy-MM")</span>
                                <span class="stat-label">创建日期</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    @* ===== 空状态 ===== *@
    <div class="empty-state">
        <i class="bi bi-inbox"></i>
        <h3>还没有项目</h3>
        <p class="text-muted">创建您的第一个项目，开始构建 Alpaca 数据集</p>
        <a asp-controller="Project" asp-action="Create" class="btn btn-primary btn-lg mt-3">
            <i class="bi bi-plus-lg"></i> 创建第一个项目
        </a>
    </div>
}

@* ===== 工作流程 ===== *@
<div class="workflow-section">
    <h5 class="workflow-title"><i class="bi bi-diagram-3"></i> 工作流程</h5>
    <div class="workflow-steps">
        <div class="workflow-step">
            <span class="step-number">1</span>
            <span class="step-label">创建项目</span>
        </div>
        <i class="bi bi-arrow-right workflow-arrow"></i>
        <div class="workflow-step">
            <span class="step-number">2</span>
            <span class="step-label">上传文档</span>
        </div>
        <i class="bi bi-arrow-right workflow-arrow"></i>
        <div class="workflow-step">
            <span class="step-number">3</span>
            <span class="step-label">分段解析</span>
        </div>
        <i class="bi bi-arrow-right workflow-arrow"></i>
        <div class="workflow-step">
            <span class="step-number">4</span>
            <span class="step-label">LLM 生成 QA</span>
        </div>
        <i class="bi bi-arrow-right workflow-arrow"></i>
        <div class="workflow-step">
            <span class="step-number">5</span>
            <span class="step-label">导出 JSONL</span>
        </div>
    </div>
</div>
