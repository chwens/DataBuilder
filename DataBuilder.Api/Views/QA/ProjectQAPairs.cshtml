@model ProjectQAViewModel
@using DataBuilder.Core.Entities
@{
    ViewData["Title"] = $"数据集 - {Model.Project.Name}";
    var projectId = Model.Project.Id;
}

<div class="container-fluid">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @errMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* 项目信息头（标题+括号数字 · 视觉铁律 #6） *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-collection"></i>
                        <span class="title-count">数据集<span class="count">(@Model.TotalCount)</span></span>
                        <span class="text-secondary ms-2" style="font-size: 0.85rem; font-weight: 400;">@Model.Project.Name</span>
                    </h4>
                    <p class="text-secondary mb-0">
                        项目内所有问答对（QA pairs），按所属文档片段（Chunk）分组；可选择导出全部或选中条目。
                    </p>
                </div>
                <div class="text-end">
                    <span class="chip chip-blue">@Model.TotalCount 条</span>
                    <span class="chip chip-green ms-1">@Model.AnsweredCount 条已回答</span>
                </div>
            </div>
        </div>
    </div>

    @* 类型筛选栏 + 批量导出操作（sticky 操作栏 · 视觉铁律 #10） *@
    <div class="toolbar-sticky">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <form method="get" class="d-flex align-items-center gap-2" id="filterForm">
                <input type="hidden" name="projectId" value="@projectId" />
                <label for="filterType" class="form-label mb-0 text-secondary">类型筛选：</label>
                <select name="filterType" id="filterType" class="form-select form-select-sm col-control" style="width: auto;" onchange="this.form.submit()">
                    <option value="">全部类型</option>
                    @foreach (var type in Model.TypeList)
                    {
                        @if (type == Model.FilterType)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </form>
            <div class="d-flex gap-2">
                <button id="btnExportSelected" class="btn btn-l1" disabled>
                    <i class="bi bi-download"></i> 导出选中
                </button>
                <a asp-controller="Export" asp-action="Download" asp-route-projectId="@projectId" class="btn btn-l2">
                    <i class="bi bi-download"></i> 导出全部
                </a>
            </div>
        </div>
    </div>

    @* 空状态 *@
    @if (!Model.QAPairs.Any())
    {
        <partial name="_QAEmptyState" model="@(("bi-collection", "该项目下还没有任何问答对", "请先到「问题」Tab 确认问题已生成，然后到「数据源」Tab 对待回答问题批量生成答案。", $"/Project/Detail/{projectId}", "前往数据源"))" />
    }
    else
    {
        @* 按 Chunk 分组渲染 QA 列表 *@
        var grouped = Model.QAPairs
            .GroupBy(q => q.ChunkId)
            .OrderBy(g => g.Key);

        @foreach (var group in grouped)
        {
            var firstQa = group.First();
            var chunk = firstQa.Chunk;
            var docFileName = chunk?.Document?.FileName ?? "(未知文档)";

            <partial name="_QAGroupHeader" model="@((docFileName, chunk?.Sequence ?? 0, group.Count()))" />

            <div class="card mb-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;"><input type="checkbox" class="qa-group-selectall" data-group="@(chunk?.Id ?? 0)"></th>
                                    <th style="width: 60px;">序号</th>
                                    <th style="width: 30%;">问题</th>
                                    <th>答案</th>
                                    <th style="width: 100px;">状态</th>
                                    <th style="width: 180px;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int index = 1;
                                }
                                @foreach (var qa in group)
                                {
                                    var rowModel = new QAPairRowViewModel
                                    {
                                        QAPair = qa,
                                        Index = index++,
                                        ShowCheckbox = true,
                                        ShowAnswer = true,
                                        IsSelected = false
                                    };
                                    <partial name="_QAPairTableRow" model="rowModel" />
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        (function() {
            var btnExport = document.getElementById('btnExportSelected');
            var checkboxes = document.querySelectorAll('.qa-checkbox');

            function updateExportButton() {
                var anyChecked = false;
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].checked) {
                        anyChecked = true;
                        break;
                    }
                }
                btnExport.disabled = !anyChecked;
            }

            // 跨组全选（每个 Chunk 组自己的全选 checkbox）
            document.querySelectorAll('.qa-group-selectall').forEach(function(groupBox) {
                groupBox.addEventListener('change', function() {
                    var card = this.closest('.card');
                    if (!card) return;
                    card.querySelectorAll('.qa-checkbox').forEach(function(cb) {
                        cb.checked = groupBox.checked;
                    });
                    updateExportButton();
                });
            });

            for (var i = 0; i < checkboxes.length; i++) {
                checkboxes[i].addEventListener('change', updateExportButton);
            }

            btnExport.addEventListener('click', function() {
                var selectedIds = [];
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].checked) {
                        selectedIds.push(checkboxes[i].value);
                    }
                }
                if (selectedIds.length === 0) return;
                window.location.href = '/Export/ExportSelected?qaIds=' + selectedIds.join(',');
            });
        })();
    </script>
}
