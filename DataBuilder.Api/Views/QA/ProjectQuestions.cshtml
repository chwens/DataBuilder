@model ProjectQAViewModel
@using DataBuilder.Core.Entities
@{
    ViewData["Title"] = $"问题管理 - {Model.Project.Name}";
    var projectId = Model.Project.Id;
}

<div class="container-fluid">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @errMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* 项目信息头（标题+括号数字 · 视觉铁律 #6） *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-question-circle"></i>
                        <span class="title-count">问题<span class="count">(@Model.TotalCount)</span></span>
                        <span class="text-secondary ms-2" style="font-size: 0.85rem; font-weight: 400;">@Model.Project.Name</span>
                    </h4>
                    <p class="text-secondary mb-0">
                        跨项目内所有文档生成的问题，按所属文档片段（Chunk）分组。
                    </p>
                </div>
                <div class="text-end">
                    <span class="chip chip-blue">@Model.TotalCount 条问题</span>
                    @if (Model.AnsweredCount > 0)
                    {
                        <span class="chip chip-green ms-1">@Model.AnsweredCount 条已生成答案</span>
                    }
                    @* 5 张统计图折叠按钮（Bootstrap Collapse） *@
                    <button class="btn btn-l2 ms-2" type="button"
                            data-bs-toggle="collapse" data-bs-target="#stats-panel-@projectId"
                            aria-expanded="false" aria-controls="stats-panel-@projectId">
                        <i class="bi bi-bar-chart-line"></i> 查看数据统计
                        <i class="bi bi-chevron-down ms-1 toggle-icon"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* 5 张统计图（默认折叠，点击上方按钮展开；图表 ID 用 stats-panel-{projectId} 防止冲突） *@
    @await Html.PartialAsync("/Views/Project/_StatsPartial.cshtml", projectId)

    @* 类型筛选栏（sticky 操作栏 · 视觉铁律 #10） *@
    <div class="toolbar-sticky">
        <div class="d-flex justify-content-between align-items-center gap-2">
            <form method="get" class="d-flex align-items-center gap-2">
                <input type="hidden" name="projectId" value="@projectId" />
                <label for="filterType" class="form-label mb-0 text-secondary">类型筛选：</label>
                <select name="filterType" id="filterType" class="form-select form-select-sm col-control" style="width: auto;" onchange="this.form.submit()">
                    <option value="">全部类型</option>
                    @foreach (var type in Model.TypeList)
                    {
                        @if (type == Model.FilterType)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
            </form>
            <a asp-controller="QA" asp-action="ProjectQAPairs" asp-route-projectId="@projectId"
               class="btn btn-l2">
                <i class="bi bi-collection"></i> 前往数据集 Tab
            </a>
        </div>
    </div>

    @* 空状态：未生成问题 *@
    @if (!Model.QAPairs.Any())
    {
        <partial name="_QAEmptyState" model="@(("bi-question-circle", "该项目下还没有任何问题", "请到「数据源」Tab 选择文档生成问题。生成完成后，问题会按文档片段（Chunk）显示在此页面。", $"/Project/Detail/{projectId}", "前往数据源"))" />
    }
    else
    {
        @* 按 Chunk 分组渲染问题列表 *@
        var grouped = Model.QAPairs
            .GroupBy(q => q.ChunkId)
            .OrderBy(g => g.Key);

        @foreach (var group in grouped)
        {
            var firstQa = group.First();
            var chunk = firstQa.Chunk;
            var docFileName = chunk?.Document?.FileName ?? "(未知文档)";

            <partial name="_QAGroupHeader" model="@((docFileName, chunk?.Sequence ?? 0, group.Count()))" />

            <div class="card mb-3">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 60px;">序号</th>
                                    <th>问题</th>
                                    <th style="width: 100px;">类型</th>
                                    <th style="width: 100px;">状态</th>
                                    <th style="width: 120px;">操作</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var qa in group)
                                {
                                    var rowModel = new QAPairRowViewModel
                                    {
                                        QAPair = qa,
                                        Index = index++,
                                        ShowCheckbox = false,
                                        ShowAnswer = false,
                                        IsSelected = qa.Answered
                                    };
                                    <partial name="_QAPairTableRow" model="rowModel" />
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
<script src="~/js/stats/project-stats.js" asp-append-version="true"></script>
}
