@model QAPreviewViewModel
@{
    ViewData["Title"] = "问答对管理 - " + Model.Document.FileName;
    var projectId = ViewData["ProjectId"] as int? ?? Model.Document.ProjectId;
}

<div class="container-fluid">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @errMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Document.Status == DocumentStatus.Done
         && Model.QAPairs.Any()
         && Model.QAPairs.All(q => string.IsNullOrWhiteSpace(q.Topic)))
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>主题标签尚未生成</strong>：当前文档的问答对还未完成主题打标，统计页主题分布图将不显示。可点击下方「重新打标」手动生成。
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="关闭"></button>
        </div>
    }

    @* 文档信息头（标题+括号数字 · 视觉铁律 #6） *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-1">
                        <i class="bi bi-file-earmark-text"></i>
                        <span class="title-count">问答对管理<span class="count">(@Model.TotalCount)</span></span>
                    </h4>
                    <p class="text-secondary mb-0">
                        <i class="bi bi-file-earmark"></i> @Model.Document.FileName
                        <span class="ms-2"><i class="bi bi-clock"></i> @Model.Document.CreatedAt.ToBeijingTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                    </p>
                </div>
                <div class="text-end">
                    <span class="chip chip-blue">@Model.Document.Status</span>
                </div>
            </div>
        </div>
    </div>

    @* 类型筛选栏 + 统计信息（sticky 操作栏 · 视觉铁律 #10） *@
    <div class="toolbar-sticky">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <form method="get" class="d-flex align-items-center gap-2" id="filterForm">
                    @* 保留 documentId / projectId，避免 GET 表单提交时丢失路由参数导致 404 *@
                    @if (ViewData["IsProjectView"] is true)
                    {
                        <input type="hidden" name="projectId" value="@projectId" />
                    }
                    else
                    {
                        <input type="hidden" name="documentId" value="@Model.Document.Id" />
                    }
                    <label for="filterType" class="form-label mb-0 text-secondary">类型筛选：</label>
                    <select name="filterType" id="filterType" class="form-select form-select-sm col-control" style="width: auto;" onchange="this.form.submit()">
                        <option value="">全部类型</option>
                        @foreach (var type in Model.TypeList)
                        {
                            @if (type == Model.FilterType)
                            {
                                <option value="@type" selected>@type</option>
                            }
                            else
                            {
                                <option value="@type">@type</option>
                            }
                        }
                    </select>
                </form>
            </div>
            <div>
                <span class="text-secondary">共 <span class="chip chip-blue">@Model.TotalCount 条</span> @Model.AnsweredCount 条已回答</span>
            </div>
        </div>
    </div>

    @* 文档 Chunk 数量，供前端 JS 计算进度百分比 *@
    @{
        int chunkCount = Model.Document.Chunks?.Count ?? 0;
    }

    @if (!Model.QAPairs.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">生成问题</h5>
            </div>
            <div class="card-body">
                <form asp-action="GenerateQuestions" method="post" class="generate-form" data-total="@chunkCount">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="documentId" value="@Model.Document.Id" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="qaType" class="form-label">问题类型</label>
                            <select name="qaType" id="qaType" class="form-select">
                                <option value="Factoid">Factoid - 事实型</option>
                                <option value="Reasoning">Reasoning - 推理型</option>
                                <option value="Summary">Summary - 总结型</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="countPerChunk" class="form-label">每片段问题数</label>
                            <select name="countPerChunk" id="countPerChunk" class="form-select">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3" selected>3</option>
                                <option value="5">5</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-l1 w-100">开始生成问题</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.QAPairs.Any())
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">问题列表</h5>
                <div>
                    @{
                        int unansweredCount = Model.QAPairs.Count(q => !q.Answered);
                    }
                    @if (unansweredCount > 0)
                    {
                        <form asp-action="GenerateAnswers" method="post" class="d-inline generate-form" data-total="@unansweredCount" onsubmit="return false;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                            <button type="submit" class="btn btn-l3-magic">生成全部答案</button>
                        </form>
                    }
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="selectAll"></th>
                                <th style="width: 60px;">序号</th>
                                <th>问题</th>
                                <th>答案</th>
                                <th style="width: 100px;">状态</th>
                                <th style="width: 200px;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var qa in Model.QAPairs)
                            {
                                var rowModel = new QAPairRowViewModel
                                {
                                    QAPair = qa,
                                    Index = index++,
                                    ShowCheckbox = true,
                                    ShowAnswer = true,
                                    IsSelected = qa.Answered
                                };
                                <partial name="_QAPairTableRow" model="rowModel" />
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* 底部批量导出（sticky 底栏 · 视觉铁律 #10） *@
        <div class="toolbar-sticky-bottom">
            <div class="d-flex gap-2">
                <button id="btnExportSelected" class="btn btn-l1" disabled>导出选中</button>
                <a asp-controller="Export" asp-action="Download" asp-route-projectId="@projectId" class="btn btn-l2">导出全部</a>
                <form asp-action="RetagTopics" method="post" class="d-inline generate-form" data-total="1" onsubmit="return false;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="documentId" value="@Model.Document.Id" />
                    <button type="submit" class="btn btn-l2">重新打标</button>
                </form>
            </div>
        </div>
    }
</div>

@* 生成进度条遮罩层（默认隐藏，JS 控制显示/隐藏） *@
<div id="progressOverlay" class="progress-overlay" style="display: none;">
    <div class="progress-card" id="progressCard">
        <div class="progress-card-title">
            <span class="spinner-icon"></span>
            <span class="error-icon" style="display:none;"><i class="bi bi-exclamation-triangle"></i></span>
            <span class="check-icon" style="display:none;"><i class="bi bi-check-circle"></i></span>
            <span id="progressStage">正在生成...</span>
        </div>
        <p class="progress-card-desc" id="progressDesc">正在连接 LLM 服务</p>
        <div class="progress">
            <div class="progress-bar" id="progressBar" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <div class="progress-card-stats">
            <span id="progressCurrent">0</span>
            <span id="progressPercent">0%</span>
            <span id="progressTotal">/ 0</span>
        </div>
        <p class="progress-card-footer" id="progressFooter">请耐心等待，不要关闭页面</p>
    </div>
</div>

@section Scripts {
    <script>
        // ===== 复选框 / 导出逻辑（原有功能，保持不变） =====
        (function() {
            var selectAll = document.getElementById('selectAll');
            var checkboxes = document.querySelectorAll('.qa-checkbox');
            var btnExport = document.getElementById('btnExportSelected');

            if (!selectAll || checkboxes.length === 0) return;

            function updateSelectAll() {
                if (checkboxes.length === 0) return;
                var allChecked = true;
                for (var i = 0; i < checkboxes.length; i++) {
                    if (!checkboxes[i].checked) {
                        allChecked = false;
                        break;
                    }
                }
                selectAll.checked = allChecked;
            }

            function updateExportButton() {
                var anyChecked = false;
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].checked) {
                        anyChecked = true;
                        break;
                    }
                }
                if (btnExport) btnExport.disabled = !anyChecked;
            }

            selectAll.addEventListener('change', function() {
                for (var i = 0; i < checkboxes.length; i++) {
                    checkboxes[i].checked = selectAll.checked;
                }
                updateExportButton();
            });

            for (var i = 0; i < checkboxes.length; i++) {
                checkboxes[i].addEventListener('change', function() {
                    updateSelectAll();
                    updateExportButton();
                });
            }

            if (btnExport) {
                btnExport.addEventListener('click', function() {
                    var selectedIds = [];
                    for (var i = 0; i < checkboxes.length; i++) {
                        if (checkboxes[i].checked) {
                            selectedIds.push(checkboxes[i].value);
                        }
                    }
                    if (selectedIds.length === 0) return;
                    window.location.href = '/Export/ExportSelected?qaIds=' + selectedIds.join(',');
                });
            }
        })();

        // ===== 生成进度条逻辑 =====
        (function() {
            var documentId = @Model.Document.Id;
            var pollTimer = null;
            var overlay = document.getElementById('progressOverlay');
            var progressCard = document.getElementById('progressCard');
            var progressBar = document.getElementById('progressBar');
            var progressStage = document.getElementById('progressStage');
            var progressDesc = document.getElementById('progressDesc');
            var progressCurrent = document.getElementById('progressCurrent');
            var progressTotal = document.getElementById('progressTotal');
            var progressPercent = document.getElementById('progressPercent');
            var progressFooter = document.getElementById('progressFooter');
            var spinnerIcon = progressCard.querySelector('.spinner-icon');
            var errorIcon = progressCard.querySelector('.error-icon');
            var checkIcon = progressCard.querySelector('.check-icon');

            function showProgress() {
                overlay.style.display = 'flex';
                progressCard.classList.remove('error', 'completed');
                progressBar.style.width = '0%';
                progressBar.setAttribute('aria-valuenow', '0');
                progressCurrent.textContent = '0';
                progressPercent.textContent = '0%';
                progressFooter.textContent = '请耐心等待，不要关闭页面';
                spinnerIcon.style.display = 'inline-block';
                errorIcon.style.display = 'none';
                checkIcon.style.display = 'none';
            }

            function updateProgress(data) {
                var pct = data.percent || 0;
                progressBar.style.width = pct + '%';
                progressBar.setAttribute('aria-valuenow', pct);
                progressCurrent.textContent = data.current || 0;
                progressTotal.textContent = '/ ' + (data.total || 0);
                progressPercent.textContent = pct + '%';
                if (data.stage) {
                    progressStage.textContent = data.stage;
                    progressDesc.textContent = '已完成 ' + (data.current || 0) + ' / ' + (data.total || 0);
                }
            }

            function showCompleted(data) {
                progressCard.classList.add('completed');
                spinnerIcon.style.display = 'none';
                errorIcon.style.display = 'none';
                checkIcon.style.display = 'inline-block';
                progressBar.style.width = '100%';
                progressBar.setAttribute('aria-valuenow', '100');
                progressPercent.textContent = '100%';
                progressStage.textContent = '生成完成';
                progressDesc.textContent = '页面即将刷新...';
                progressFooter.textContent = '正在跳转';
            }

            function showError(errorMsg) {
                progressCard.classList.add('error');
                spinnerIcon.style.display = 'none';
                checkIcon.style.display = 'none';
                errorIcon.style.display = 'inline-block';
                progressBar.style.width = '100%';
                progressBar.setAttribute('aria-valuenow', '100');
                progressPercent.textContent = '失败';
                progressStage.textContent = '生成失败';
                progressDesc.textContent = errorMsg || '未知错误';
                progressFooter.textContent = '请关闭后重试';
            }

            function startPolling() {
                stopPolling();
                pollTimer = setInterval(function() {
                    fetch('/QA/GenerateProgress/' + documentId, {
                        headers: { 'Accept': 'application/json' }
                    })
                    .then(function(resp) { return resp.json(); })
                    .then(function(data) {
                        if (!data || !data.isRunning) {
                            // 可能已完成或出错
                            if (data) {
                                if (data.isCompleted) {
                                    showCompleted(data);
                                    stopPolling();
                                    // 延迟刷新，让用户看到 100% 完成状态
                                    setTimeout(function() {
                                        window.location.href = '/QA/Preview/' + documentId;
                                    }, 800);
                                } else if (data.isError) {
                                    showError(data.errorMessage || '服务器处理出错');
                                    stopPolling();
                                }
                            }
                            return;
                        }
                        updateProgress(data);
                    })
                    .catch(function() {
                        // 网络错误，忽略（等待下次轮询）
                    });
                }, 500);
            }

            function stopPolling() {
                if (pollTimer) {
                    clearInterval(pollTimer);
                    pollTimer = null;
                }
            }

            // 拦截所有 .generate-form 表单提交
            var generateForms = document.querySelectorAll('.generate-form');
            for (var i = 0; i < generateForms.length; i++) {
                (function(form) {
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();

                        // 如果是"重新打标"表单，需要确认
                        if (form.action.indexOf('RetagTopics') !== -1) {
                            if (!confirm('将对全部问题重新聚类归一化主题，已有主题标签会被覆盖（LLM 结果可能变化）。继续？')) {
                                return;
                            }
                        }

                        // 如果是"生成全部答案"表单，需要确认
                        var isAnswerForm = form.action.indexOf('GenerateAnswers') !== -1;
                        if (isAnswerForm) {
                            if (!confirm('确认要为所有待回答问题生成答案吗？')) {
                                return;
                            }
                        }

                        // 先清除上一次的进度记录（如果有的话）
                        fetch('/QA/GenerateProgressClear/' + documentId, {
                            method: 'POST'
                        }).catch(function() {});

                        showProgress();

                        var formData = new FormData(form);

                        // 延迟启动轮询（给服务器一点时间开始处理）
                        setTimeout(function() {
                            startPolling();
                        }, 300);

                        // 通过 fetch 提交表单
                        fetch(form.action, {
                            method: 'POST',
                            body: formData,
                            headers: {
                                'RequestVerificationToken': formData.get('__RequestVerificationToken')
                            }
                        })
                        .then(function(response) {
                            stopPolling();

                            if (response.redirected) {
                                // 服务器返回重定向，说明成功，跳转到目标页面
                                showCompleted({});
                                setTimeout(function() {
                                    window.location.href = response.url;
                                }, 800);
                            } else if (!response.ok) {
                                // HTTP 错误
                                return response.text().then(function(text) {
                                    showError('服务器返回错误 (' + response.status + '): ' + (text || '').substring(0, 200));
                                });
                            } else {
                                // 成功但无重定向（不太可能，作为降级处理）
                                window.location.href = '/QA/Preview/' + documentId;
                            }
                        })
                        .catch(function(err) {
                            stopPolling();
                            showError('网络请求失败: ' + err.message);
                        });
                    });
                })(generateForms[i]);
            }
        })();
    </script>
}
