@model QAPreviewViewModel
@{
    ViewData["Title"] = "问答对管理 - " + Model.Document.FileName;
    var projectId = ViewData["ProjectId"] as int? ?? Model.Document.ProjectId;
}

<div class="container-fluid">

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] is string errMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @errMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* 类型筛选栏 + 统计信息 *@
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <form method="get" class="d-flex align-items-center gap-2" id="filterForm">
                        @* 保留 documentId / projectId，避免 GET 表单提交时丢失路由参数导致 404 *@
                        @if (ViewData["IsProjectView"] is true)
                        {
                            <input type="hidden" name="projectId" value="@projectId" />
                        }
                        else
                        {
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                        }
                        <label for="filterType" class="form-label mb-0">类型筛选：</label>
                        <select name="filterType" id="filterType" class="form-select form-select-sm" style="width: auto;" onchange="this.form.submit()">
                            <option value="">全部类型</option>
                            @foreach (var type in Model.TypeList)
                            {
                                @if (type == Model.FilterType)
                                {
                                    <option value="@type" selected>@type</option>
                                }
                                else
                                {
                                    <option value="@type">@type</option>
                                }
                            }
                        </select>
                    </form>
                </div>
                <div>
                    <span class="text-muted">共 @Model.TotalCount 条，@Model.AnsweredCount 条已回答</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">文档信息</h5>
            <span class="badge bg-info">@Model.Document.Status</span>
        </div>
        <div class="card-body">
            <p><strong>文件名：</strong>@Model.Document.FileName</p>
            <p><strong>创建时间：</strong>@Model.Document.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
        </div>
    </div>

    @if (!Model.QAPairs.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">生成问题</h5>
            </div>
            <div class="card-body">
                <form asp-action="GenerateQuestions" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="documentId" value="@Model.Document.Id" />
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="qaType" class="form-label">问题类型</label>
                            <select name="qaType" id="qaType" class="form-select">
                                <option value="Factoid">Factoid - 事实型</option>
                                <option value="Reasoning">Reasoning - 推理型</option>
                                <option value="Summary">Summary - 总结型</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="countPerChunk" class="form-label">每片段问题数</label>
                            <select name="countPerChunk" id="countPerChunk" class="form-select">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="3" selected>3</option>
                                <option value="5">5</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">开始生成问题</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }

    @if (Model.QAPairs.Any())
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">问题列表</h5>
                <div>
                    @if (Model.QAPairs.Any(q => !q.Answered))
                    {
                        <form asp-action="GenerateAnswers" method="post" class="d-inline" onsubmit="return confirm('确认要为所有待回答问题生成答案吗？')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="documentId" value="@Model.Document.Id" />
                            <button type="submit" class="btn btn-success">生成全部答案</button>
                        </form>
                    }
                </div>
            </div>
            <div class="card-body p-0">
                @* 批量操作栏 *@
                <div class="p-2 border-bottom d-flex gap-2">
                    <button id="btnExportSelected" class="btn btn-sm btn-primary" disabled>导出选中</button>
                    <a asp-controller="Export" asp-action="Download" asp-route-projectId="@projectId" class="btn btn-sm btn-outline-secondary">导出全部</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40px;"><input type="checkbox" id="selectAll"></th>
                                <th style="width: 60px;">序号</th>
                                <th>问题</th>
                                <th>答案</th>
                                <th style="width: 100px;">状态</th>
                                <th style="width: 200px;">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var qa in Model.QAPairs)
                            {
                                <tr>
                                    <td><input type="checkbox" class="qa-checkbox" value="@qa.Id"></td>
                                    <td>@(index++)</td>
                                    <td>
                                        @if (qa.Instruction.Length > 100)
                                        {
                                            <span title="@qa.Instruction">@qa.Instruction.Substring(0, 100)...</span>
                                        }
                                        else
                                        {
                                            @qa.Instruction
                                        }
                                    </td>
                                    <td>
                                        @if (qa.Answered)
                                        {
                                            if (qa.Output.Length > 100)
                                            {
                                                <span title="@qa.Output">@qa.Output.Substring(0, 100)...</span>
                                            }
                                            else
                                            {
                                                @qa.Output
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">— 待生成 —</span>
                                        }
                                    </td>
                                    <td>
                                        @if (qa.Answered)
                                        {
                                            <span class="badge bg-success">已回答</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">待生成</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="EditQuestion" asp-route-id="@qa.Id" class="btn btn-sm btn-outline-primary" title="编辑问题">编辑问题</a>
                                        @if (qa.Answered)
                                        {
                                            <a asp-action="EditAnswer" asp-route-id="@qa.Id" class="btn btn-sm btn-outline-secondary" title="编辑答案">编辑答案</a>
                                        }
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('确认要删除这条问答对吗？')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@qa.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">删除</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        (function() {
            var selectAll = document.getElementById('selectAll');
            var checkboxes = document.querySelectorAll('.qa-checkbox');
            var btnExport = document.getElementById('btnExportSelected');

            function updateSelectAll() {
                if (checkboxes.length === 0) return;
                var allChecked = true;
                for (var i = 0; i < checkboxes.length; i++) {
                    if (!checkboxes[i].checked) {
                        allChecked = false;
                        break;
                    }
                }
                selectAll.checked = allChecked;
            }

            function updateExportButton() {
                var anyChecked = false;
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].checked) {
                        anyChecked = true;
                        break;
                    }
                }
                btnExport.disabled = !anyChecked;
            }

            selectAll.addEventListener('change', function() {
                for (var i = 0; i < checkboxes.length; i++) {
                    checkboxes[i].checked = selectAll.checked;
                }
                updateExportButton();
            });

            for (var i = 0; i < checkboxes.length; i++) {
                checkboxes[i].addEventListener('change', function() {
                    updateSelectAll();
                    updateExportButton();
                });
            }

            btnExport.addEventListener('click', function() {
                var selectedIds = [];
                for (var i = 0; i < checkboxes.length; i++) {
                    if (checkboxes[i].checked) {
                        selectedIds.push(checkboxes[i].value);
                    }
                }
                if (selectedIds.length === 0) return;
                window.location.href = '/Export/ExportSelected?qaIds=' + selectedIds.join(',');
            });
        })();
    </script>
}
