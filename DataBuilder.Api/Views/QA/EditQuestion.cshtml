@model QAEditViewModel
@{
    ViewData["Title"] = "编辑问题";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首页</a></li>
            <li class="breadcrumb-item active">编辑问题</li>
        </ol>
    </nav>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">编辑问题 #@Model.QAPair.Id</h5>
        </div>
        <div class="card-body">
            <form asp-action="EditQuestion" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.QAPair.Id" />

                <div class="mb-3">
                    <label for="instruction" class="form-label fw-bold">问题文本</label>
                    <textarea id="instruction" name="instruction" rows="5" class="form-control">@Model.QAPair.Instruction</textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">保存</button>
                    <a href="@(Model.ReturnUrl ?? Url.Action("Preview", "QA", new { documentId = Model.QAPair.Chunk?.DocumentId ?? 0 }))" class="btn btn-secondary">返回</a>
                </div>
            </form>
        </div>
    </div>
</div>
