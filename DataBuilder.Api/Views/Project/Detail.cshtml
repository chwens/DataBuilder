@model ProjectDetailViewModel
@using DataBuilder.Core.Entities
@{
    ViewData["Title"] = Model.Project.Name;
    var currentLLM = ViewData["CurrentLLMConfig"] as LLMConfig;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] is string errMsg)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- 项目信息头卡片（标题+括号数字 · 视觉铁律 #6） -->
<div class="project-header-card">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div class="flex-grow-1">
            <h3 class="project-header-title">
                @Model.Project.Name
                <span class="title-count ms-2" style="font-size: 0.7em;">
                    <span class="count">(ID #@Model.Project.Id)</span>
                </span>
            </h3>
            @if (!string.IsNullOrEmpty(Model.Project.Description))
            {
                <p class="project-header-desc">@Model.Project.Description</p>
            }
            <div class="project-header-meta">
                <span><i class="bi bi-calendar-plus"></i> 创建: @Model.Project.CreatedAt.ToBeijingTime().ToString("yyyy-MM-dd HH:mm")</span>
                <span><i class="bi bi-pencil-square"></i> 更新: @Model.Project.UpdatedAt.ToBeijingTime().ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        </div>
        <div class="d-flex gap-2 flex-shrink-0">
            <a asp-action="Settings" asp-route-id="@Model.Project.Id" asp-route-tab="model" class="btn btn-l4">
                <i class="bi bi-cpu"></i> 模型设置
            </a>
            <a asp-action="Settings" asp-route-id="@Model.Project.Id" class="btn btn-l4">
                <i class="bi bi-gear"></i> 项目设置
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Project.Id" method="post"
                  onsubmit="return confirm('确定删除该项目及其所有数据吗？此操作不可撤销。');">
                <button type="submit" class="btn btn-l3-danger">
                    <i class="bi bi-trash3"></i> 删除项目
                </button>
            </form>
        </div>
    </div>
    <div class="d-flex align-items-center gap-2 mt-2 pt-2 border-top">
        <span class="text-secondary" style="font-size:0.85rem;">
            <i class="bi bi-cpu"></i> 当前模型：
        </span>
        @if (currentLLM != null)
        {
            <span class="chip chip-purple">
                @currentLLM.ModelName (@currentLLM.Provider) — @currentLLM.ModelLabel
            </span>
            @if (currentLLM.IsDeleted)
            {
                <span class="chip chip-red">
                    <i class="bi bi-exclamation-triangle"></i> 模型已失效
                </span>
            }
        }
        else
        {
            <span class="chip chip-orange">
                <i class="bi bi-exclamation-triangle"></i> 未选择模型
            </span>
        }
        <a asp-action="Settings" asp-route-id="@Model.Project.Id" asp-route-tab="model" class="ms-auto btn btn-link btn-sm">
            <i class="bi bi-arrow-right-circle"></i> 切换模型
        </a>
    </div>
</div>

<!-- 文档区域：标题 + 操作（sticky 操作栏 · 视觉铁律 #10） -->
<div class="toolbar-sticky">
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="section-header-title">
            <input type="checkbox" class="form-check-input me-2" id="selectAllDocs" style="margin:0;width:1rem;height:1rem;cursor:pointer">
            <i class="bi bi-file-earmark-text"></i> 文档列表
            @if (Model.Documents.Any())
            {
                <span class="section-header-count">@Model.Documents.Count()</span>
            }
        </h4>
        <div class="d-flex gap-2">
            <button type="button" id="btnBatchDelete" class="btn btn-l3-danger d-none" onclick="batchDeleteDocs()">
                <i class="bi bi-trash3"></i> 批量删除
            </button>
            <a asp-controller="Document" asp-action="Upload" asp-route-projectId="@Model.Project.Id" class="btn btn-l1">
                <i class="bi bi-cloud-upload"></i> 上传文档
            </a>
        </div>
    </div>
</div>

@if (!Model.Documents.Any())
{
    <partial name="_QAEmptyState" model="@(("bi-inbox", "暂无文档", "点击\"上传文档\"按钮添加 .md 或 .txt 文件，开始构建数据集。", $"/Document/Upload?projectId={Model.Project.Id}", "上传第一篇文档"))" />
}
else
{
    <div class="doc-card-list">
        @foreach (var doc in Model.Documents)
        {
            <div class="doc-card">
                <div class="doc-card-body">
                    <!-- 左侧：复选框 -->
                    <div class="doc-card-check">
                        <input type="checkbox" class="form-check-input doc-checkbox" value="@doc.Id">
                    </div>
                    <!-- 中间：文件名 + 状态 + 元信息 -->
                    <div class="doc-card-info">
                        <div class="doc-card-title-row">
                            <a asp-controller="Document" asp-action="Chunks" asp-route-id="@doc.Id" class="doc-card-title">
                                @doc.FileName
                            </a>
                            @switch (doc.Status)
                            {
                                case DocumentStatus.Uploaded:
                                    <span class="chip chip-gray">已上传</span>
                                    break;
                                case DocumentStatus.Parsing:
                                    <span class="chip chip-orange">解析中</span>
                                    break;
                                case DocumentStatus.Parsed:
                                    <span class="chip chip-blue">已解析</span>
                                    break;
                                case DocumentStatus.Generating:
                                    <span class="chip chip-orange">生成中</span>
                                    break;
                                case DocumentStatus.Done:
                                    <span class="chip chip-green">已生成</span>
                                    break;
                                default:
                                    <span class="chip chip-gray">@doc.Status</span>
                                    break;
                            }
                        </div>
                        <div class="doc-card-meta">
                            <span><i class="bi bi-clock"></i> 上传于 @doc.CreatedAt.ToBeijingTime().ToString("yyyy-MM-dd HH:mm")</span>
                        </div>
                    </div>
                    <!-- 右侧：操作按钮 -->
                    <div class="doc-card-actions">
                        <a asp-controller="Document" asp-action="Chunks" asp-route-id="@doc.Id"
                           class="btn-icon-circle" title="分段管理" data-bs-toggle="tooltip">
                            <i class="bi bi-list-ol"></i>
                        </a>
                        <a asp-controller="QA" asp-action="Preview" asp-route-documentId="@doc.Id"
                           class="btn-icon-circle btn-icon-circle-primary" title="QA 管理" data-bs-toggle="tooltip">
                            <i class="bi bi-chat-square-text"></i>
                        </a>
                        <form asp-controller="Document" asp-action="Delete" asp-route-id="@doc.Id" method="post"
                              onsubmit="return confirm('确定删除该文档及其所有数据吗？');" class="d-inline">
                            <button type="submit" class="btn-icon-circle btn-icon-circle-danger" title="删除文档" data-bs-toggle="tooltip">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- 底部操作 -->
<div class="mt-4 d-flex gap-2">
    <a asp-controller="Export" asp-action="Download" asp-route-projectId="@Model.Project.Id" class="btn btn-l1">
        <i class="bi bi-download"></i> 导出数据集
    </a>
    <a asp-controller="QA" asp-action="ProjectQAPairs" asp-route-projectId="@Model.Project.Id"
       class="btn btn-l2">
        <i class="bi bi-eye"></i> 查看所有问答
    </a>
</div>

@section Scripts {
<script>
    document.getElementById('selectAllDocs').addEventListener('change', function() {
        var checkboxes = document.querySelectorAll('.doc-checkbox');
        checkboxes.forEach(function(cb) { cb.checked = this.checked; }.bind(this));
        toggleBatchButtons();
    });

    document.querySelectorAll('.doc-checkbox').forEach(function(cb) {
        cb.addEventListener('change', toggleBatchButtons);
    });

    function toggleBatchButtons() {
        var checkedCount = document.querySelectorAll('.doc-checkbox:checked').length;
        var btnDelete = document.getElementById('btnBatchDelete');
        if (checkedCount > 0) {
            btnDelete.classList.remove('d-none');
        } else {
            btnDelete.classList.add('d-none');
        }
    }

    function batchDeleteDocs() {
        var checked = document.querySelectorAll('.doc-checkbox:checked');
        if (checked.length === 0) return;
        if (!confirm('确定要删除选中的 ' + checked.length + ' 篇文档吗？此操作不可撤销。')) return;
        var ids = Array.from(checked).map(function(cb) { return cb.value; });
        var form = document.createElement('form');
        form.method = 'post';
        form.action = '/Document/BatchDelete';
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'ids';
        input.value = ids.join(',');
        form.appendChild(input);
        var token = document.createElement('input');
        token.type = 'hidden';
        token.name = '__RequestVerificationToken';
        token.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
        form.appendChild(token);
        document.body.appendChild(form);
        form.submit();
    }
</script>
}
