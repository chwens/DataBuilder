@model ProjectDetailViewModel
@{
    ViewData["Title"] = Model.Project.Name;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">项目列表</a></li>
        <li class="breadcrumb-item active">@Model.Project.Name</li>
    </ol>
</nav>

<div class="card mb-4">
    <div class="card-body">
        <h3 class="card-title">@Model.Project.Name</h3>
        @if (!string.IsNullOrEmpty(Model.Project.Description))
        {
            <p class="card-text">@Model.Project.Description</p>
        }
        <p class="text-muted small">
            创建时间: @Model.Project.CreatedAt.ToString("yyyy-MM-dd HH:mm") |
            更新时间: @Model.Project.UpdatedAt.ToString("yyyy-MM-dd HH:mm")
        </p>
        <div class="d-flex gap-2">
            <a asp-action="Settings" asp-route-id="@Model.Project.Id" class="btn btn-outline-secondary">Prompt 设置</a>
            <form asp-action="Delete" asp-route-id="@Model.Project.Id" method="post"
                  onsubmit="return confirm('确定删除该项目及其所有数据吗？此操作不可撤销。');">
                <button type="submit" class="btn btn-outline-danger">删除项目</button>
            </form>
        </div>
    </div>
</div>

<h4>文档列表</h4>

@if (!Model.Documents.Any())
{
    <div class="alert alert-info">
        暂无文档。
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>文件名</th>
                <th>状态</th>
                <th>上传时间</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var doc in Model.Documents)
        {
            <tr>
                <td>
                    <a asp-controller="Document" asp-action="Chunks" asp-route-id="@doc.Id">
                        @doc.FileName
                    </a>
                </td>
                <td>
                    @switch (doc.Status)
                    {
                        case DocumentStatus.Uploaded:
                            <span class="badge bg-secondary">已上传</span>
                            break;
                        case DocumentStatus.Parsing:
                            <span class="badge bg-warning text-dark">解析中</span>
                            break;
                        case DocumentStatus.Parsed:
                            <span class="badge bg-info">已解析</span>
                            break;
                        case DocumentStatus.Generating:
                            <span class="badge bg-warning text-dark">生成中</span>
                            break;
                        case DocumentStatus.Done:
                            <span class="badge bg-success">已生成</span>
                            break;
                        default:
                            <span class="badge bg-light text-dark">@doc.Status</span>
                            break;
                    }
                </td>
                <td>@doc.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a asp-controller="Document" asp-action="Chunks" asp-route-id="@doc.Id"
                       class="btn btn-sm btn-outline-primary">分段</a>
                    <a asp-controller="QA" asp-action="Preview" asp-route-documentId="@doc.Id"
                       class="btn btn-sm btn-outline-success">QA 管理</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<div class="mt-3 d-flex gap-2">
    <a asp-controller="Document" asp-action="Upload" asp-route-projectId="@Model.Project.Id" class="btn btn-primary">上传文档</a>
    <a asp-controller="Export" asp-action="Download" asp-route-projectId="@Model.Project.Id" class="btn btn-success">导出数据集</a>
</div>
