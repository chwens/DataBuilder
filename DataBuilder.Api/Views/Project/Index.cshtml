@model ProjectListViewModel
@{
    ViewData["Title"] = "项目管理";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0"><i class="bi bi-folder2-open"></i> 项目管理</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> 新建项目
    </a>
</div>

@if (!Model.Projects.Any())
{
    <div class="empty-state">
        <i class="bi bi-folder-x"></i>
        <h3>暂无项目</h3>
        <p class="text-muted">创建一个新项目，上传文档开始构建数据集。</p>
        <a asp-action="Create" class="btn btn-primary mt-3">
            <i class="bi bi-plus-lg"></i> 创建第一个项目
        </a>
    </div>
}
else
{
    <div class="project-list-cards">
        @foreach (var project in Model.Projects)
        {
            var firstLetter = string.IsNullOrEmpty(project.Name)
                ? "P"
                : project.Name[0].ToString().ToUpper();
            <div class="project-list-card">
                <div class="project-list-card-body">
                    <div class="project-list-card-info">
                        <div class="project-list-card-icon">
                            <span>@firstLetter</span>
                        </div>
                        <div class="project-list-card-text">
                            <a asp-action="Detail" asp-route-id="@project.Id" class="project-list-card-title">
                                @project.Name
                            </a>
                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <p class="project-list-card-desc">@project.Description</p>
                            }
                            <span class="project-list-card-date">
                                <i class="bi bi-calendar-plus"></i> @project.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                            </span>
                        </div>
                    </div>
                    <div class="project-list-card-actions">
                        <a asp-action="Settings" asp-route-id="@project.Id"
                           class="btn-icon-circle" title="Prompt 设置" data-bs-toggle="tooltip">
                            <i class="bi bi-gear"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="d-inline"
                              onsubmit="return confirm('确定删除该项目及其所有数据吗？此操作不可撤销。');">
                            <button type="submit" class="btn-icon-circle btn-icon-circle-danger"
                                    title="删除" data-bs-toggle="tooltip">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
