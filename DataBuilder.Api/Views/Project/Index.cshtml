@model ProjectListViewModel
@{
    ViewData["Title"] = "项目列表";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-folder"></i> 项目列表</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> 新建项目</a>
</div>

@if (!Model.Projects.Any())
{
    <div class="alert alert-info">暂无项目，请先创建一个项目。</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>名称</th>
                <th>描述</th>
                <th>创建时间</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var project in Model.Projects)
        {
            <tr>
                <td>
                    <a asp-action="Detail" asp-route-id="@project.Id">@project.Name</a>
                </td>
                <td>@(project.Description ?? "-")</td>
                <td>@project.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <div class="btn-group">
                        <a asp-action="Settings" asp-route-id="@project.Id" class="btn btn-sm btn-outline-secondary">设置</a>
                        <form asp-action="Delete" asp-route-id="@project.Id" method="post" class="d-inline"
                              onsubmit="return confirm('确定删除该项目及其所有数据吗？此操作不可撤销。');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">删除</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
