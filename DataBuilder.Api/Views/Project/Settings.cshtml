@model ProjectSettingsViewModel
@{
    ViewData["Title"] = $"项目设置 - {Model.Project.Name}";
    var activeTab = (ViewBag.ActiveTab as string ?? "basic").ToLowerInvariant();
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<!-- ==================== 成功 / 失败提示 ==================== -->
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ==================== 页面标题 ==================== -->
<div class="page-header-card">
    <i class="bi bi-gear page-header-icon"></i>
    <div>
        <h1 class="page-header-title">项目设置</h1>
        <p class="page-header-desc">在此管理项目的名称、模型、分块参数与提示词模板。所有变更仅对当前项目生效。</p>
    </div>
</div>

<!-- ==================== 4 Tab 导航（HTMX 2.0 无刷新切换） ==================== -->
<nav class="settings-tabs" aria-label="Settings tabs">
    <a href="?tab=basic"
       class="settings-tab @(activeTab == "basic" ? "active" : "")"
       data-tab="basic"
       hx-get="@Url.Action("Settings", new { id = Model.Project.Id, tab = "basic", partial = "true" })"
       hx-target="#settings-content"
       hx-swap="innerHTML"
       hx-push-url="true">
        <i class="bi bi-info-circle"></i> 基本信息
    </a>
    <a href="?tab=model"
       class="settings-tab @(activeTab == "model" ? "active" : "")"
       data-tab="model"
       hx-get="@Url.Action("Settings", new { id = Model.Project.Id, tab = "model", partial = "true" })"
       hx-target="#settings-content"
       hx-swap="innerHTML"
       hx-push-url="true">
        <i class="bi bi-cpu"></i> 模型配置
    </a>
    <a href="?tab=task"
       class="settings-tab @(activeTab == "task" ? "active" : "")"
       data-tab="task"
       hx-get="@Url.Action("Settings", new { id = Model.Project.Id, tab = "task", partial = "true" })"
       hx-target="#settings-content"
       hx-swap="innerHTML"
       hx-push-url="true">
        <i class="bi bi-sliders"></i> 任务配置
    </a>
    <a href="?tab=prompt"
       class="settings-tab @(activeTab == "prompt" ? "active" : "")"
       data-tab="prompt"
       hx-get="@Url.Action("Settings", new { id = Model.Project.Id, tab = "prompt", partial = "true" })"
       hx-target="#settings-content"
       hx-swap="innerHTML"
       hx-push-url="true">
        <i class="bi bi-chat-quote"></i> 提示词配置
    </a>
</nav>

<!-- ==================== Tab 内容容器 ==================== -->
<div id="settings-content">
    @* 首次加载：服务端渲染当前 active tab（JS 禁用时也能看） *@
    @switch (activeTab)
    {
        case "model":
            @await Html.PartialAsync("Settings/_Model", Model)
            break;
        case "task":
            @await Html.PartialAsync("Settings/_Task", Model)
            break;
        case "prompt":
            @await Html.PartialAsync("Settings/_Prompt", Model)
            break;
        default:
            @await Html.PartialAsync("Settings/_Basic", Model)
            break;
    }
</div>

@section Scripts {
<script>
// ==================== HTMX 事件后重新绑定交互 ====================
// 每次 HTMX 替换 #settings-content 后，重新执行 Slider 和恢复默认按钮的初始化。
document.body.addEventListener('htmx:afterSwap', function(evt) {
    if (evt.target.id !== 'settings-content') return;
    initTaskConfigSliders();
    initResetPromptButtons();
    // 滚动到内容顶部（用户感知的"切换完成"反馈）
    var content = document.getElementById('settings-content');
    if (content) {
        content.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
});

// ==================== Tab 激活态切换 ====================
// HTMX 在请求完成前先发 htmx:beforeRequest，但内容替换是 afterSwap。
// 这里在请求发出后立即高亮新 Tab，避免用户视觉等待。
document.body.addEventListener('htmx:beforeRequest', function(evt) {
    if (!evt.target.classList || !evt.target.classList.contains('settings-tab')) return;
    document.querySelectorAll('.settings-tab').forEach(function(t) { t.classList.remove('active'); });
    evt.target.classList.add('active');
});

// ==================== Slider 实时显示 ====================
function initTaskConfigSliders() {
    document.querySelectorAll('#settings-content .task-config-slider').forEach(function(slider) {
        if (slider.dataset.initialized === '1') return;
        slider.dataset.initialized = '1';
        slider.addEventListener('input', function() {
            var badgeId = this.dataset.target;
            var badge = document.getElementById(badgeId);
            if (badge) {
                var suffix = this.dataset.suffix || '';
                badge.textContent = this.value + suffix;
            }
        });
    });
}

// ==================== 提示词恢复默认（Phase E1：按需 fetch） ====================
function initResetPromptButtons() {
    document.querySelectorAll('#settings-content .reset-prompt-btn').forEach(function(btn) {
        if (btn.dataset.initialized === '1') return;
        btn.dataset.initialized = '1';
        btn.addEventListener('click', async function() {
            if (!confirm('确定要恢复为默认模板吗？当前编辑内容将丢失。')) return;
            var kind = this.dataset.kind;
            var textareaName = kind === 'question' ? 'questionPrompt' : 'answerPrompt';
            var textarea = document.querySelector('#settings-content textarea[name="' + textareaName + '"]');
            if (!textarea) return;
            try {
                var response = await fetch('/Project/GetDefaultPrompt?kind=' + encodeURIComponent(kind));
                if (!response.ok) {
                    alert('加载默认模板失败：HTTP ' + response.status);
                    return;
                }
                var data = await response.json();
                if (data && typeof data.prompt === 'string') {
                    textarea.value = data.prompt;
                }
            } catch (err) {
                alert('加载默认模板出错：' + err.message);
            }
        });
    });
}

// 首次加载绑定（兜底——服务端已渲染初始 partial）
initTaskConfigSliders();
initResetPromptButtons();
</script>
}
