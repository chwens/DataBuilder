@model ProjectCreateViewModel
@{
    ViewData["Title"] = "新建项目";
}


<div class="card shadow-sm">
    <div class="card-body">
        <h2>新建项目</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">项目名称</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">项目描述（可选）</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> 创建</button>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> 返回</a>
</form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
