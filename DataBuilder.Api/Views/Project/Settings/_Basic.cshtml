@model ProjectSettingsViewModel

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-info-circle"></i> 基本信息</h5>
    </div>
    <div class="card-body">
        <form asp-action="UpdateBasic" asp-route-id="@Model.Project.Id" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label for="name" class="form-label fw-bold">
                    <i class="bi bi-folder"></i> 项目名称 <span class="text-danger">*</span>
                </label>
                <input id="name" name="name" type="text" class="form-control" maxlength="200"
                       value="@Model.Project.Name" required />
                <div class="form-text">最多 200 个字符，创建后仍可修改。</div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label fw-bold">
                    <i class="bi bi-text-paragraph"></i> 项目描述
                </label>
                <textarea id="description" name="description" class="form-control" rows="3" maxlength="1000"
                          placeholder="简要描述项目的用途、目标数据特征等">@Model.Project.Description</textarea>
                <div class="form-text">最多 1000 个字符，可选填。</div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> 保存基本信息
                </button>
                <a asp-action="Detail" asp-route-id="@Model.Project.Id" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> 返回项目
                </a>
            </div>
        </form>
    </div>
</div>
