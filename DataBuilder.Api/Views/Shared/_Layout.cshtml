@inject Microsoft.Extensions.Options.IOptions<DataBuilder.Api.Models.SiteOptions> SiteConfig
@{
    var hasProjectId = ViewData["ProjectId"] != null;
    var projectIdValue = ViewData["ProjectId"];
}

@functions {
    /// <summary>
    /// 判断指定 Tab 是否应在当前页面激活。
    /// </summary>
    /// <param name="tabKey">
    /// Tab 标识，可选值：
    ///   "data-source" — 数据源 Tab（对应 Project/Detail 页面）
    ///   "questions"   — 问题 Tab（对应 QA/ProjectQuestions 页面）
    ///   "qa-pairs"    — 数据集 Tab（对应 QA/ProjectQAPairs 页面）
    ///   "settings"    — 项目设置下拉项（对应 Project/Settings 页面，仅用于「更多」下拉高亮）
    /// </param>
    /// <returns>激活返回 true，否则 false</returns>
    bool IsTabActive(string tabKey)
    {
        // 方案 C 混合实现：RouteData 为主，ViewData["ActiveTab"] 作为显式 override。
        // 当 Controller 需要强制激活某 Tab（例如重定向后激活不同 Tab）时，
        // 在 Action 里写 ViewData["ActiveTab"] = "xxx" 即可绕过 RouteData 判断。

        // 1. 显式 override 优先
        var explicitTab = ViewData["ActiveTab"] as string;
        if (!string.IsNullOrEmpty(explicitTab))
        {
            return string.Equals(explicitTab, tabKey, StringComparison.OrdinalIgnoreCase);
        }

        // 2. 默认：基于 RouteData 推断
        var controller = ViewContext.RouteData.Values["controller"] as string;
        var action = ViewContext.RouteData.Values["action"] as string;

        // 映射约定（用户确认）：
        //   document 级 QA 预览 → 数据源
        //   编辑问题 → 问题；编辑答案 → 数据集
        //   分段/上传 → 数据源；导出 → 数据集
        return (tabKey ?? string.Empty).ToLowerInvariant() switch
        {
            "data-source" =>
                (controller == "Project" && action == "Detail") ||
                (controller == "Document" && (action == "Upload" || action == "Chunks" || action == "Parse")) ||
                (controller == "QA" && action == "Preview"),

            "questions" =>
                controller == "QA" && (action == "ProjectQuestions" || action == "EditQuestion"),

            "qa-pairs" =>
                (controller == "QA" && (action == "ProjectQAPairs" || action == "EditAnswer")) ||
                (controller == "Export" && action == "Download"),

            "settings" =>
                controller == "Project" && action == "Settings",

            _ => false,
        };
    }
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @SiteConfig.Value.AppName</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataBuilder.Api.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-dark top-navbar fixed-top">
        <div class="container-fluid d-flex align-items-center">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon" aria-hidden="true">
                    <!-- 24×24 数据集堆积图（currentColor 主题色） -->
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="3" y="13" width="18" height="3" rx="1" fill="currentColor" opacity="0.4" />
                        <rect x="3" y="8"  width="18" height="3" rx="1" fill="currentColor" opacity="0.7" />
                        <rect x="3" y="3"  width="18" height="3" rx="1" fill="currentColor" />
                    </svg>
                </span>
                <span class="brand-text">@SiteConfig.Value.AppName</span>
            </a>
            <div class="navbar-actions ms-auto">
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "LLMConfig" ? "active" : "")"
                   asp-controller="LLMConfig" asp-action="Index">
                    <i class="bi bi-cpu"></i> 模型配置
                </a>
            </div>
        </div>
    </nav>

    @if (hasProjectId)
    {
        <div class="project-tabs">
            <div class="container-fluid">
                <ul class="nav project-tabs-nav">
                    <li class="nav-item">
                        <a class="nav-link @(IsTabActive("data-source") ? "active" : "")"
                           asp-controller="Project" asp-action="Detail" asp-route-id="@projectIdValue">
                            <i class="bi bi-database"></i> 数据源
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsTabActive("questions") ? "active" : "")"
                           asp-controller="QA" asp-action="ProjectQuestions" asp-route-projectId="@projectIdValue">
                            <i class="bi bi-question-circle"></i> 问题
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(IsTabActive("qa-pairs") ? "active" : "")"
                           asp-controller="QA" asp-action="ProjectQAPairs" asp-route-projectId="@projectIdValue">
                            <i class="bi bi-collection"></i> 数据集
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-three-dots"></i> 更多
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item @(IsTabActive("settings") ? "active" : "")"
                                   asp-controller="Project" asp-action="Settings" asp-route-id="@projectIdValue">
                                    <i class="bi bi-gear"></i> 项目设置
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post"
                                      asp-controller="Project"
                                      asp-action="Delete"
                                      asp-route-id="@projectIdValue"
                                      onsubmit="return confirm('确定删除此项目及其所有文档？');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-trash"></i> 删除项目
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    }

    <div class="main-content @(hasProjectId ? "has-tabs" : "")">
        <main>
            @RenderBody()
        </main>
        <footer class="footer mt-4">
            <div>
                @SiteConfig.Value.Footer
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @* HTMX 2.0 — 方案 B 核心：Settings 4 Tab 无刷新切换（~14KB gzip，CDN 引入） *@
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.3/dist/htmx.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
