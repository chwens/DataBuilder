<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataBuilder.Api</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DataBuilder.Api.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="bi bi-database-fill-gear"></i>
                DataBuilder
            </div>
            <nav class="sidebar-nav">
                <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i> 工作台
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Project" ? "active" : "")"
                   asp-controller="Project" asp-action="Index">
                    <i class="bi bi-folder"></i> 项目管理
                </a>
            </nav>
        </aside>

        <div class="main-content">
            <main>
                @RenderBody()
            </main>
            <footer class="footer mt-4">
                <div>
                    &copy; 2026 - DataBuilder - Alpaca 数据集构建系统
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
